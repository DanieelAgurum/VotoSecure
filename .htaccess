# = ========================================================
# 🔧 ACTIVAR REESCRITURA DE URLS
# = ========================================================
RewriteEngine On
RewriteBase /votosecure/

# = ========================================================
# ✅ EXCEPCIONES PERMITIDAS (Rutas específicas)
# = ========================================================
RewriteRule ^vista/registradores/?$ vista/Registradores/RegistroVotantes.php [L,QSA,NC]
RewriteRule ^vista/resultados/?$ vista/resultados.php [L,QSA,NC]
RewriteRule ^vista/candidatos/?$ vista/candidatos.php [L,QSA,NC]
RewriteRule ^vista/propuestas/?$ vista/propuestas.php [L,QSA,NC]
RewriteRule ^vista/resultados/?$ vista/resultados.php [L,QSA,NC]
RewriteRule ^vista/login/?$ vista/login.php [L,QSA,NC]

# Administrador
RewriteRule ^vista/admin/index/?$ vista/admin/index.php [L,QSA,NC]
RewriteRule ^vista/admin/votantes/?$ vista/admin/Votantes.php [L,QSA,NC]
RewriteRule ^vista/admin/elecciones/?$ vista/admin/Elecciones.php [L,QSA,NC]
RewriteRule ^vista/admin/resultados/?$ vista/admin/Resultados.php [L,QSA,NC]
RewriteRule ^vista/admin/partidos/?$ vista/admin/Partidos.php [L,QSA,NC]
RewriteRule ^vista/admin/candidatos/?$ vista/admin/Candidatos.php [L,QSA,NC]
RewriteRule ^vista/admin/propuestas/?$ vista/admin/Propuestas.php [L,QSA,NC]
RewriteRule ^vista/admin/registros/?$ vista/admin/Registros.php [L,QSA,NC]
RewriteRule ^vista/admin/reportes/?$ vista/admin/Reportes.php [L,QSA,NC]

#Votantes
RewriteRule ^vista/votantes/?$ vista/votantes/Plantilla.php [L,QSA,NC]
RewriteRule ^vista/votantes/plantilla/?$ vista/votantes/Plantilla.php [L,QSA,NC]

# = ========================================================
# 🔒 EVITAR LISTADO DE DIRECTORIOS
# = ========================================================
Options -Indexes
# = ========================================================
# ✅ PERMITIR ARCHIVOS Y DIRECTORIOS EXISTENTES
# = ========================================================
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# = ========================================================
# ⚠️ PÁGINAS DE ERROR PERSONALIZADAS
# = ========================================================
ErrorDocument 403 /votosecure/vista/403.php
ErrorDocument 404 /votosecure/vista/404.php
